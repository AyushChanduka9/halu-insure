# Copy this file to `.env` in the project root (never commit real secrets).
#
# Used by Hardhat for `npx hardhat run scripts/deploy.js --network sepolia`:

# HTTPS JSON-RPC URL for Sepolia (Infura, Alchemy, public provider, etc.)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# Deployer wallet private key — pays gas on Sepolia (test ETH only).
# 64 hex characters, with or without 0x prefix.
PRIVATE_KEY=0x_your_deployer_private_key_here
